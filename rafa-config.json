{
  "project_name": "My Project",

  "linear": {
    "enabled": true,
    "todo_state_name": "Todo",
    "in_progress_state_name": "In Progress",
    "done_state_name": "In Review"
  },

  "slack": {
    "enabled": true,
    "notify_channel_id": "YOUR_SLACK_CHANNEL_ID",
    "notify_on": ["task_start", "task_done", "all_complete", "error"]
  },

  "git": {
    "auto_commit": true,
    "commit_message_prefix": "rafa:"
  },

  "task_selection": {
    "skip_statuses": ["pending", "done", "in_progress", "failed"],
    "skip_owners": ["human"]
  },

  "tdd": {
    "enabled": false
  }
}
