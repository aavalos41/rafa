# ─────────────────────────────────────────────────────────────
# Rafa Environment Variables
# Copy this file to .env and fill in values if needed.
# NEVER commit .env to git — it's already in .gitignore.
# ─────────────────────────────────────────────────────────────
#
# Linear and Slack are handled through Claude Code's MCP connections
# (authenticated at claude.ai/settings/integrations) — no API keys needed here.
#
# ── Git (optional — only if not set globally) ─────────────────
# GIT_AUTHOR_NAME="Rafa Bot"
# GIT_AUTHOR_EMAIL="rafa@yourproject.com"
