# ─────────────────────────────────────────────────────────────
# Rafa Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it's already in .gitignore.
# Each person on the team has their own .env with their own keys.
# ─────────────────────────────────────────────────────────────

# ── Linear ───────────────────────────────────────────────────
# Personal API key from: Linear → Settings → API → Personal API keys
# Required if linear.enabled = true in rafa-config.json
LINEAR_API_KEY=  # paste your Linear Personal API key here (starts with lin_api_)

# ── Slack — DM mode (recommended) ────────────────────────────
# Create a Slack app at api.slack.com/apps with scopes: chat:write, im:write
# Install it to your workspace and copy the Bot Token below.
# Required if slack.mode = "dm" in rafa-config.json
SLACK_BOT_TOKEN=  # paste your Bot Token here (starts with xoxb-)

# Your personal Slack user ID (the person who receives the DMs).
# Find it in Slack: click your name → View profile → ⋯ → Copy member ID
SLACK_NOTIFY_USER_ID=UXXXXXXXXXX

# ── Slack — Webhook mode (alternative) ───────────────────────
# Use this instead of the bot token if you prefer channel posts over DMs.
# Create an Incoming Webhook at api.slack.com/apps → Incoming Webhooks
# Required if slack.mode = "webhook" in rafa-config.json
# SLACK_WEBHOOK_URL=  # paste your Incoming Webhook URL here

# ── Git (optional — usually already configured globally) ──────
# Only needed if your git user isn't set globally
# GIT_AUTHOR_NAME="Rafa Bot"
# GIT_AUTHOR_EMAIL="rafa@yourproject.com"
